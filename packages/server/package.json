    "argon2": "^0.41.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.38.0",
    "express": "^4.21.0",
    "jose": "^5.9.0",
    "mammoth": "^1.11.0",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
