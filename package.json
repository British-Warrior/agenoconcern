{
  "name": "indomitable-unity",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm run dev:server & pnpm run dev:web",
    "dev:server": "pnpm --filter @indomitable-unity/server dev",
    "dev:web": "pnpm --filter @indomitable-unity/web dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "db:generate": "pnpm --filter @indomitable-unity/server db:generate",
    "db:migrate": "pnpm --filter @indomitable-unity/server db:migrate",
    "db:push": "pnpm --filter @indomitable-unity/server drizzle-kit push",
    "db:studio": "pnpm --filter @indomitable-unity/server db:studio",
    "test": "pnpm -r test"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
